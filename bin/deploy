#!/bin/bash

# Exit immediately if any command fails
set -e

# Default to main branch if no argument is passed
BASE_BRANCH="${1:-main}"

# 1. Protect against deploying half-baked code
if [ -n "$(git status --porcelain)" ]; then
  echo "❌ Error: Your working directory has uncommitted changes. Commit or stash them first."
  exit 1
fi

echo "🚀 Starting streamlined deployment workflow..."

# 2. Sync with Git remote to ensure you are deploying up-to-date code
echo "🔄 Syncing with origin/$BASE_BRANCH..."
git checkout "$BASE_BRANCH"
git pull origin "$BASE_BRANCH"

# 3. Clear any broken local asset caches on your Mac
echo "🧹 Clearing local asset caches..."
bin/rails assets:clobber

# 4. Trigger Kamal using your specific production environment file
echo "🚢 Streaming context to Hetzner Remote Builder..."
bundle exec kamal deploy --env-file .env.production

echo "🎉 Deployment successful!"
