#!/bin/bash

set -e

TEMP_BRANCH="kamal-deploy-$(date +%s)"
BASE_BRANCH="${1:-${BASE_BRANCH:-main}}"

# Check if working directory is clean
if [ -n "$(git status --porcelain)" ]; then
  echo "❌ Error: Your working directory has uncommitted changes. Clean them up first."
  exit 1
fi

# Cleanup trap, runs no matter what (even if deploy fails)
cleanup() {
  echo "🧹 Cleaning up deployment branches..."
  git checkout -f "$BASE_BRANCH" > /dev/null 2>&1
  git branch -D "$TEMP_BRANCH" > /dev/null 2>&1
  echo "✨ Back on $BASE_BRANCH. Temp branch deleted."
}
trap cleanup EXIT

echo "🚀 Starting deployment workflow..."

# 1. Sync with origin and cut the isolated deploy branch
git checkout "$BASE_BRANCH"
git fetch origin main
git pull origin main
git checkout -b "$TEMP_BRANCH"

# 2. Clear out any broken local asset caches on your Mac
echo "🧹 Clearing local asset caches..."
bin/rails assets:clobber

# 3. Deploy with Kamal using your specific production environment file
echo "🚢 Deploying with Kamal via Hetzner Remote Builder..."
kamal deploy --env-file .env.production

echo "🎉 Deployment successful!"
