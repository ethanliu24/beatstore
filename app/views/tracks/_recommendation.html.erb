<div id="<%= "recs-#{rec}" %>" data-controller="button-scroll" class="w-full">
  <div class="flex justify-between items-center">
    <h2 class="tracking-wider text-sm mb-2"><%= rec %></h2>

    <div class="flex justify-end items-center gap-1">
      <button data-action="click->button-scroll#scrollLeft" class="hover:bg-hover cursor-pointer rounded-full p-1">
        <%= icon "chevron-left", class: "w-4 h-4 aspect-square" %>
      </button>
      <button data-action="click->button-scroll#scrollRight" class="hover:bg-hover cursor-pointer rounded-full p-1">
        <%= icon "chevron-right", class: "w-4 h-4 aspect-square" %>
      </button>
      <% if see_more_link %>
        <%= link_to t("track.recommendation.see_more"), see_more_link, class: "text-[0.6rem] hover:underline ml-2" %>
      <% end %>
    </div>
  </div>

  <div class="flex justify-start items-stretch gap-2 overflow-x-auto hide-scrollbar" data-button-scroll-target="container">
    <% tracks.each do |track| %>
      <%= render partial: "tracks/rec_card", locals: { track:, queue_scope: "pages:home:rec_#{rec}", p: 2, c_size: 38, hover_bg: "secondary-bg" } %>
    <% end %>
  </div>
</div>
