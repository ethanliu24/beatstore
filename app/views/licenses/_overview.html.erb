<div class="flex flex-col justify-start items-center gap-2 bg-secondary-bg p-4 max-w-50 text-[0.6rem]">
  <%= content_tag :p, license.title, class: "font-bold" %>

  <% if license.contract_type == License.contract_types[:exclusive] %>
    <%= content_tag :p, "MAKE AN OFFER", class: "text-xl font-bold text-center" %>
  <% else %>
    <%= content_tag :p, license.price.format, class: "text-2xl font-bold text-center" %>
  <% end %>

  <ul class="list-disc pl-4 text-wrap mb-2">
    <% overview.each do |line| %>
      <li><%= line %></li>
    <% end %>
  </ul>

  <div class="flex-1 flex flex-col justify-end items-center w-full">
    <% if license.contract_type == License.contract_types[:exclusive] %>
      <p class="text-[0.5rem] font-light mb-1 italic"><%= "Email #{::Credentials::Email.producer_email} or" %></p>
      <%= link_to t("pages.licensing.contact_btn"), contact_path, target: "_blank", rel: "noopener",
        class: "license-overview-btn" %>
    <% else %>
      <%= link_to t("pages.licensing.read_license_btn"),
        preview_contract_modal_path(license_id: license.id),
        data: { turbo_stream: true },
        class: "license-overview-btn" %>
    <% end %>
  </div>
</div>
