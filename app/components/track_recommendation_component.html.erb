<div id="<%= "track-recommendation-#{recommendation.group}" %>"
  class="flex flex-col justify-between items-stretch gap-4 w-50 p-4 rounded hover:bg-hover">
  <div class="w-full aspect-square rounded flex justify-center items-center bg-secondary-bg cursor-pointer">
    <%= link_to explore_tracks_path(anchor: "recs-#{recommendation.group}"),
      data: { turbo: false },
      class: "w-full h-full flex justify-center items-center" do %>
      <% if recommendation.display_image.attached? %>
        <%= image_tag url_for(recommendation.display_image), class: "w-full h-full rounded" %>
      <% else %>
        <%= icon "photo-scan", class: "w-1/4 h-1/4" %>
      <% end %>
    <% end %>
  </div>
  <div class="w-full flex justify-center items-center">
    <%= render DynamicTagsComponent.new(
      tags: recommendation.tag_names.map{ |t| Track::Tag.new(name: t) },
      resource: recommendation,
      rerender_on_resize: true
    ) %>
  </div>
</div>
